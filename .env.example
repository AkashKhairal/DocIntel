# ========================================
# DocIntel — Environment Variables
# ========================================

# --- App ---
API_KEY=                          # Optional: protect /chat endpoint
DEBUG=false

# --- OpenAI ---
# Can also be set via the Settings UI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Ollama (optional, for local LLM) ---
USE_OLLAMA=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3

# --- Embedding ---
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Google Drive ---
# Can also be set via the Settings UI
GOOGLE_CREDENTIALS_JSON=          # raw JSON string of service account credentials
GOOGLE_DRIVE_FOLDER_ID=           # root folder ID to watch
WEBHOOK_URL=                      # public HTTPS URL (e.g. ngrok)

# --- Chunking ---
CHUNK_SIZE=500
CHUNK_OVERLAP=100
